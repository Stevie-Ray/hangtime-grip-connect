{
  "name": "grip-connect",
  "private": true,
  "license": "BSD-2-Clause",
  "author": "Stevie-Ray Hartog <mail@stevie-ray.nl>",
  "repository": {
    "type": "git"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "dev:cli": "npm run dev --workspace ./packages/cli",
    "dev:docs": "npm run docs:dev --workspace ./packages/docs",
    "dev:examples:capacitor": "npm run start --workspace ./examples/capacitor",
    "dev:examples:app": "npm run dev --workspace ./examples/app",
    "dev:examples:flappy-bird": "npm run dev --workspace ./examples/flappy-bird",
    "dev:examples:aurora": "npm run dev --workspace ./examples/aurora",
    "dev:examples:pong": "npm run dev --workspace ./examples/pong",
    "dev:examples:react-native": "npm run start --workspace ./examples/react-native",
    "dev:examples:runtime": "npm run start --workspace ./examples/runtime",
    "preview:docs": "npm run preview --workspace ./packages/docs",
    "preview:examples:capacitor": "npm run preview --workspace ./examples/capacitor",
    "preview:examples:app": "npm run preview --workspace ./examples/app",
    "preview:examples:flappy-bird": "npm run preview --workspace ./examples/flappy-bird",
    "preview:examples:aurora": "npm run preview --workspace ./examples/aurora",
    "preview:examples:pong": "npm run preview --workspace ./examples/pong",
    "preview:examples:react-native": "npm run preview --workspace ./examples/react-native",
    "build": "tsc --build --verbose --force && npm run build:core",
    "build:capacitor": "npm run build --workspace ./packages/capacitor",
    "build:cli": "npm run build --workspace ./packages/cli",
    "build:core": "npm run build --workspace ./packages/core",
    "build:docs": "npm run docs:build --workspace ./packages/docs",
    "build:react-native": "npm run build --workspace ./packages/react-native",
    "build:runtime": "npm run build --workspace ./packages/runtime",
    "build:examples:capacitor": "npm run build && npm run build --workspace ./examples/capacitor",
    "build:examples:app": "npm run build && npm run build --workspace ./examples/app",
    "build:examples:flappy-bird": "npm run build && npm run build --workspace ./examples/flappy-bird",
    "build:examples:aurora": "npm run build && npm run build --workspace ./examples/aurora",
    "build:examples:pong": "npm run build && npm run build --workspace ./examples/pong",
    "build:examples:react-native": "npm run build && npm run build --workspace ./examples/react-native",
    "test:core": "npm run test --workspace ./packages/core",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:version:ci": "changeset version && npm run sync:deno-versions && npm run format",
    "changeset:publish": "changeset publish",
    "sync:deno-versions": "node scripts/sync-deno-versions.mjs",
    "check:deno-versions": "node scripts/check-deno-versions.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.20.1",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript/native": "npm:typescript@^7.0.2",
    "husky": "^9.1.7",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.73.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "engines": {
    "node": ">=22"
  }
}
